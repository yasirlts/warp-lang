{
  "name": "@warp-lang/commerce-registry",
  "version": "0.1.0",
  "private": true,
  "description": "A mechanism for describing and indexing community commerce adapters: a documented manifest format (name, platform, inbound/outbound capability, conformance status), a local in-memory index, and a validator. It is a format plus tooling, not a hosted registry service — it stores nothing remotely, fetches nothing, and runs no adapter.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "example": "node examples/register-existing-adapters.mjs"
  },
  "keywords": [
    "commerce",
    "adapter",
    "registry",
    "manifest",
    "warp"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yasirlts/warp-lang",
    "directory": "packages/commerce-registry"
  },
  "homepage": "https://github.com/yasirlts/warp-lang",
  "dependencies": {
    "@warp-lang/commerce-types": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
