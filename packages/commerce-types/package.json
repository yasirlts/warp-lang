{
  "name": "@warp-lang/commerce-types",
  "version": "0.3.0",
  "description": "Formal commerce types derived from the Warp Commerce Model \u2014 typed money, validated state transitions, and the six commerce invariants.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./platforms/shopify": {
      "import": "./dist/platforms/shopify.js",
      "require": "./dist/platforms/shopify.cjs",
      "types": "./dist/platforms/shopify.d.ts"
    },
    "./platforms/woocommerce": {
      "import": "./dist/platforms/woocommerce.js",
      "require": "./dist/platforms/woocommerce.cjs",
      "types": "./dist/platforms/woocommerce.d.ts"
    },
    "./platforms/stripe": {
      "import": "./dist/platforms/stripe.js",
      "require": "./dist/platforms/stripe.cjs",
      "types": "./dist/platforms/stripe.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "commerce",
    "ecommerce",
    "types",
    "warp",
    "formal-methods",
    "order-management",
    "typescript",
    "ai-coding",
    "state-machine"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yasirlts/warp-lang",
    "directory": "packages/commerce-types"
  },
  "homepage": "https://github.com/yasirlts/warp-lang",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
