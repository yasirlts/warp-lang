{
  "name": "@warp-lang/commerce-types",
  "version": "1.1.0",
  "description": "Formal commerce types derived from the Warp Commerce Model — typed money, validated state transitions, and the six commerce invariants.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./platforms/shopify": {
      "import": {
        "types": "./dist/platforms/shopify.d.ts",
        "default": "./dist/platforms/shopify.js"
      },
      "require": {
        "types": "./dist/platforms/shopify.d.cts",
        "default": "./dist/platforms/shopify.cjs"
      }
    },
    "./platforms/woocommerce": {
      "import": {
        "types": "./dist/platforms/woocommerce.d.ts",
        "default": "./dist/platforms/woocommerce.js"
      },
      "require": {
        "types": "./dist/platforms/woocommerce.d.cts",
        "default": "./dist/platforms/woocommerce.cjs"
      }
    },
    "./platforms/stripe": {
      "import": {
        "types": "./dist/platforms/stripe.d.ts",
        "default": "./dist/platforms/stripe.js"
      },
      "require": {
        "types": "./dist/platforms/stripe.d.cts",
        "default": "./dist/platforms/stripe.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "node scripts/generate-from-schema.mjs",
    "codegen": "node scripts/generate-from-schema.mjs --check",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "commerce",
    "ecommerce",
    "types",
    "warp",
    "formal-methods",
    "order-management",
    "typescript",
    "ai-coding",
    "state-machine"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yasirlts/warp-lang",
    "directory": "packages/commerce-types"
  },
  "homepage": "https://github.com/yasirlts/warp-lang",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
