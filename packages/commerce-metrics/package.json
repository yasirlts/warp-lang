{
  "name": "@warp-lang/commerce-metrics",
  "version": "0.1.0",
  "description": "Structured metrics for Warp's commerce-integrity guardrail — wrap the published guardAction and count the blocks it returns, by rule (I-1..I-6 and guard rules) and by scope. An observability layer only: it composes @warp-lang/commerce-types and tallies verdicts; it does not change, re-derive, or weaken any guard or invariant logic.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "example": "node examples/metrics.mjs"
  },
  "dependencies": {
    "@warp-lang/commerce-types": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yasirlts/warp-lang",
    "directory": "packages/commerce-metrics"
  }
}
